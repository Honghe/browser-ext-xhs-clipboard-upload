{
  "manifest_version": 3,
  "name": "XHS Clipboard Upload",
  "version": "1.0",
  "description": "Use clipboard image to upload on Xiaohongshu",
  "permissions": [
    "clipboardRead"
  ],
  "host_permissions": [
    "https://creator.xiaohongshu.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://creator.xiaohongshu.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}